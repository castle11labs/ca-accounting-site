---
import Base from '../layouts/Base.astro';
---

<Base
  title="Services — CA Accounting | Tax, Bookkeeping, CFO, Consulting"
  description="Tax preparation and planning, outsourced bookkeeping, business incorporation, outsourced CFO, and consulting services for businesses and individuals throughout California."

>
  <!-- Header -->
  <section class="bg-cream-warm py-20 md:py-24">
    <div class="container-custom">
      <div class="max-w-3xl">
        <p class="text-forest font-semibold text-sm uppercase tracking-widest mb-6 fade-in">Services</p>
        <h1 class="text-5xl md:text-6xl font-serif text-navy leading-tight mb-6 fade-in fade-in-delay-1">
          Accounting, tax, and consulting services.
        </h1>
        <p class="text-charcoal text-lg leading-relaxed fade-in fade-in-delay-2">
          A complete suite of accounting, tax, and consulting services for businesses and individuals throughout California.
        </p>
      </div>
    </div>
  </section>

  <!-- Service nav anchors -->
  <section class="border-b border-line bg-cream py-6 sticky top-[57px] lg:top-[73px] z-40 backdrop-blur-md">
    <div class="container-custom">
      <div class="flex flex-wrap gap-x-6 gap-y-2 text-sm">
        <a href="#tax" class="text-charcoal hover:text-forest font-medium transition-colors py-2 inline-block">Tax</a>
        <a href="#accounting" class="text-charcoal hover:text-forest font-medium transition-colors py-2 inline-block">Accounting & Bookkeeping</a>
        <a href="#cfo" class="text-charcoal hover:text-forest font-medium transition-colors py-2 inline-block">CFO & Controller</a>
        <a href="#small-business" class="text-charcoal hover:text-forest font-medium transition-colors py-2 inline-block">Small Business</a>
        <a href="#incorporation" class="text-charcoal hover:text-forest font-medium transition-colors py-2 inline-block">Incorporation</a>
        <a href="#consulting" class="text-charcoal hover:text-forest font-medium transition-colors py-2 inline-block">Consulting</a>
      </div>
    </div>
  </section>

  <!-- Tax -->
  <section id="tax" class="py-20 md:py-24 scroll-mt-32 border-b border-line">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-1 fade-in">
          <p class="text-forest font-semibold text-sm uppercase tracking-widest mb-3">01</p>
          <h2 class="text-3xl md:text-4xl font-serif text-navy mb-4">Tax Services</h2>
          <p class="text-charcoal-muted text-base leading-relaxed">
            Annual tax return preparation and year-round tax minimization planning, led by an Enrolled Agent authorized by the IRS.
          </p>
        </div>
        <div class="lg:col-span-2 fade-in fade-in-delay-1">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <h3 class="font-semibold text-navy mb-2">Tax preparation</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Annual tax return preparation for individuals and businesses.</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy mb-2">Year-round tax planning</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Year-round tax minimization planning.</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy mb-2">IRS audit assistance</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Notice response and direct representation in front of the IRS by an Enrolled Agent.</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy mb-2">Estate and retirement planning</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Planning to minimize tax exposure on estates, trusts, and retirement income.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Accounting -->
  <section id="accounting" class="bg-cream-warm py-20 md:py-24 scroll-mt-32 border-b border-line">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-1 fade-in">
          <p class="text-forest font-semibold text-sm uppercase tracking-widest mb-3">02</p>
          <h2 class="text-3xl md:text-4xl font-serif text-navy mb-4">Outsourced Accounting and Bookkeeping</h2>
          <p class="text-charcoal-muted text-base leading-relaxed">
            Outsourced bookkeeping for businesses.
          </p>
        </div>
        <div class="lg:col-span-2 fade-in fade-in-delay-1">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <h3 class="font-semibold text-navy mb-2">Accounts payable and receivable</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">A managed processing workflow fit for your business.</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy mb-2">General ledger and journal entry</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Recording and classifying business transactions to keep current financials.</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy mb-2">Financial statement preparation</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Balance sheet, income statement, and cash flow reports prepared on a regular cadence.</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy mb-2">Bank and credit card reconciliations</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Reconciliation of bank and credit card accounts to keep the books accurate.</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy mb-2">Payroll services</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Fully outsourced payroll processing.</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy mb-2">Sales tax processing</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Sales tax filings for businesses with California sales tax obligations.</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy mb-2">Fixed asset and depreciation tracking</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Asset registers and depreciation schedules maintained alongside the books.</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy mb-2">Monthly closings</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">A regular monthly close so the numbers are ready when you need them.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CFO -->
  <section id="cfo" class="py-20 md:py-24 scroll-mt-32 border-b border-line">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-1 fade-in">
          <p class="text-forest font-semibold text-sm uppercase tracking-widest mb-3">03</p>
          <h2 class="text-3xl md:text-4xl font-serif text-navy mb-4">Outsourced CFO and Controller</h2>
          <p class="text-charcoal-muted text-base leading-relaxed">
            Industry and financial experience to support businesses that need senior financial leadership without the cost of a full-time hire.
          </p>
        </div>
        <div class="lg:col-span-2 fade-in fade-in-delay-1">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <h3 class="font-semibold text-navy mb-2">Cash flow management</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Regulating cash flow for budgeting and projections that support business planning.</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy mb-2">Financial reporting</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Reporting that improves the firm's accounting processes and produces higher-quality financial statements.</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy mb-2">Audits, compilations, and reviews</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Assurance services for measuring the financial standing of the company.</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy mb-2">Mergers and acquisitions</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Due diligence and transaction support on either side of a deal.</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy mb-2">Business valuation</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Valuations to support buy-sell agreements, succession, and partner transactions.</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy mb-2">QuickBooks support</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Setup, cleanup, and ongoing maintenance for QuickBooks Online and Desktop.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Small business -->
  <section id="small-business" class="bg-cream-warm py-20 md:py-24 scroll-mt-32 border-b border-line">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-1 fade-in">
          <p class="text-forest font-semibold text-sm uppercase tracking-widest mb-3">04</p>
          <h2 class="text-3xl md:text-4xl font-serif text-navy mb-4">Small Business Accounting</h2>
          <p class="text-charcoal-muted text-base leading-relaxed">
            Accounting services for small and mid-sized businesses.
          </p>
        </div>
        <div class="lg:col-span-2 fade-in fade-in-delay-1">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <h3 class="font-semibold text-navy mb-2">Outsourced bookkeeping</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Bookkeeping outsourcing so you can focus on the day-to-day operations.</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy mb-2">Cash flow management</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Forecasting and budgeting so the business knows what is coming.</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy mb-2">Financial reviews and compilations</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Bank-ready financial reports prepared to professional standards.</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy mb-2">Tax preparation and planning</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Annual returns and year-round planning for the business and its owners.</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy mb-2">Payroll services</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Fully outsourced payroll processing.</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy mb-2">Business loan assistance</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Help packaging financials for lenders.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Incorporation -->
  <section id="incorporation" class="py-20 md:py-24 scroll-mt-32 border-b border-line">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-1 fade-in">
          <p class="text-forest font-semibold text-sm uppercase tracking-widest mb-3">05</p>
          <h2 class="text-3xl md:text-4xl font-serif text-navy mb-4">Business Incorporation</h2>
          <p class="text-charcoal-muted text-base leading-relaxed">
            We help eliminate the daunting task of choosing the correct entity type and make the process as seamless as possible so you can get your company started on the right track.
          </p>
        </div>
        <div class="lg:col-span-2 fade-in fade-in-delay-1">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <h3 class="font-semibold text-navy mb-2">Entity selection</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Determining the best entity type for your new company. Each type of corporation has its own advantages and disadvantages.</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy mb-2">Business registration</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Help registering your business in California.</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy mb-2">Strategic tax planning</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Tax planning to minimize liabilities and maximize profits as the company gets started.</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy mb-2">New business advisory</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Setting up books, payroll, and tax accounts so the first year does not end in cleanup.</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy mb-2">Outsourced accounting and bookkeeping</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Professional book management so the financial side is handled from day one.</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy mb-2">QuickBooks setup and training</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Installation and training on accounting software for the new entity.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Consulting -->
  <section id="consulting" class="bg-cream-warm py-20 md:py-24 scroll-mt-32">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <div class="lg:col-span-1 fade-in">
          <p class="text-forest font-semibold text-sm uppercase tracking-widest mb-3">06</p>
          <h2 class="text-3xl md:text-4xl font-serif text-navy mb-4">Consulting</h2>
          <p class="text-charcoal-muted text-base leading-relaxed">
            Specialized consulting services.
          </p>
        </div>
        <div class="lg:col-span-2 fade-in fade-in-delay-1">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <h3 class="font-semibold text-navy mb-2">Succession and retirement planning</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Transferring ownership to the next generation, employees, or external buyers in a tax-efficient way.</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy mb-2">Estate and trust planning</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Coordination with your attorney to minimize tax exposure on trusts, estates, and gifts.</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy mb-2">Debt restructuring</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Renegotiation, consolidation, and refinance support when the current debt structure is not working.</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy mb-2">Business plan development</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Financial models and projections for fundraising, lender review, or internal planning.</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy mb-2">College savings planning</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Tax-aware funding strategies for family education savings.</p>
            </div>
            <div>
              <h3 class="font-semibold text-navy mb-2">Business valuation</h3>
              <p class="text-charcoal-muted text-sm leading-relaxed">Valuations for buy-sell agreements, gifting, or partner buyouts.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-navy text-cream py-20 md:py-24">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto text-center fade-in">
        <h2 class="text-3xl md:text-5xl font-serif text-cream mb-6">
          Not sure what you need?
        </h2>
        <p class="text-cream/80 text-lg leading-relaxed mb-10">
          That is what the consultation is for. Schedule a free initial consultation and we will recommend the right approach for your situation.
        </p>
        <a
          href="/contact"
          class="btn-modern inline-block bg-forest text-cream font-semibold px-10 py-4 rounded hover:bg-forest-hover transition-colors"
        >
          Schedule a Free Consultation
        </a>
      </div>
    </div>
  </section>
</Base>
