---
import Base from '../layouts/Base.astro';

const faq = [
  {
    q: "Where are your clients based?",
    a: "CA Accounting is a local Glendale, CA accounting firm providing local businesses and individuals with tax and accounting services throughout California.",
  },
  {
    q: "Do you offer a free consultation?",
    a: "Yes. CA Accounting offers a free initial consultation to individuals and businesses.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map((item) => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a,
    },
  })),
};
---

<Base
  title="Contact — CA Accounting | Schedule a Free Consultation"
  description="Schedule a free consultation with CA Accounting. Visit our Glendale office, call 877.500.9290, or send us a message. We respond within one business day."
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <section class="bg-cream-warm py-20 md:py-24">
    <div class="container-custom">
      <div class="max-w-3xl">
        <p class="text-forest font-semibold text-sm uppercase tracking-widest mb-6 fade-in">Contact</p>
        <h1 class="text-5xl md:text-6xl font-serif text-navy leading-tight mb-6 fade-in fade-in-delay-1">
          Let's talk.
        </h1>
        <p class="text-charcoal text-lg leading-relaxed fade-in fade-in-delay-2">
          CA Accounting offers a free initial consultation to individuals and businesses.
        </p>
      </div>
    </div>
  </section>

  <section class="py-20 md:py-24">
    <div class="container-custom">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-16">

        <!-- Form -->
        <div class="lg:col-span-3 fade-in">
          <h2 class="text-2xl font-serif text-navy mb-6">Send a message</h2>
          <form
            name="contact"
            method="POST"
            action=""
            class="space-y-6"
          >
            <input type="hidden" name="form-name" value="contact" />

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div>
                <label for="name" class="block text-charcoal text-sm font-medium mb-2">
                  Name <span class="text-forest">*</span>
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  autocomplete="name"
                  class="w-full bg-white border border-line rounded-full px-5 py-3 text-charcoal text-sm placeholder-charcoal-muted/50 focus:outline-none focus:border-forest focus:ring-2 focus:ring-forest/10 transition-all"
                  placeholder="Your full name"
                />
              </div>

              <div>
                <label for="phone" class="block text-charcoal text-sm font-medium mb-2">
                  Phone <span class="text-forest">*</span>
                </label>
                <input
                  type="tel"
                  id="phone"
                  name="phone"
                  required
                  autocomplete="tel"
                  class="w-full bg-white border border-line rounded-full px-5 py-3 text-charcoal text-sm placeholder-charcoal-muted/50 focus:outline-none focus:border-forest focus:ring-2 focus:ring-forest/10 transition-all"
                  placeholder="(555) 123-4567"
                />
              </div>
            </div>

            <div>
              <label for="business" class="block text-charcoal text-sm font-medium mb-2">
                Business name
                <span class="text-charcoal-muted font-normal">(if applicable)</span>
              </label>
              <input
                type="text"
                id="business"
                name="business"
                autocomplete="organization"
                class="w-full bg-white border border-line rounded-full px-5 py-3 text-charcoal text-sm placeholder-charcoal-muted/50 focus:outline-none focus:border-forest focus:ring-2 focus:ring-forest/10 transition-all"
                placeholder="Your company"
              />
            </div>

            <div>
              <label for="service" class="block text-charcoal text-sm font-medium mb-2">
                What can we help with?
              </label>
              <select
                id="service"
                name="service"
                class="w-full bg-white border border-line rounded-full px-5 py-3 text-charcoal text-sm focus:outline-none focus:border-forest focus:ring-2 focus:ring-forest/10 transition-all"
              >
                <option value="">Select a service</option>
                <option value="tax">Tax preparation or planning</option>
                <option value="bookkeeping">Accounting & bookkeeping</option>
                <option value="cfo">Outsourced CFO or controller</option>
                <option value="incorporation">Business incorporation</option>
                <option value="entertainment">Entertainment industry accounting</option>
                <option value="medical">Medical practice accounting</option>
                <option value="real-estate">Real estate accounting</option>
                <option value="other">Something else</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-charcoal text-sm font-medium mb-2">
                Tell us a bit about what you need
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                class="w-full bg-white border border-line rounded-2xl px-5 py-3 text-charcoal text-sm placeholder-charcoal-muted/50 focus:outline-none focus:border-forest focus:ring-2 focus:ring-forest/10 transition-all resize-y"
                placeholder="A few sentences about your business and what you're looking for"
              ></textarea>
            </div>

            <button
              type="submit"
              class="btn-modern w-full sm:w-auto bg-forest text-cream font-semibold px-10 py-4 rounded-full hover:bg-forest-hover transition-colors"
            >
              Send Message
            </button>

            <p class="text-charcoal-muted text-xs">
              Or call <a href="tel:8775009290" class="text-forest font-medium hover:text-forest-hover transition-colors">877.500.9290</a> directly.
            </p>
          </form>
        </div>

        <!-- Contact info -->
        <div class="lg:col-span-2 fade-in fade-in-delay-1">
          <h2 class="text-2xl font-serif text-navy mb-6">Get in touch</h2>

          <div class="space-y-8">
            <div>
              <p class="text-charcoal-muted text-xs uppercase tracking-widest font-semibold mb-2">Phone</p>
              <a href="tel:8775009290" class="text-2xl font-serif text-navy hover:text-forest transition-colors">
                877.500.9290
              </a>
            </div>

            <div>
              <p class="text-charcoal-muted text-xs uppercase tracking-widest font-semibold mb-2">Office</p>
              <p class="text-charcoal text-base leading-relaxed">
                300 W Glenoaks Blvd, Suite 101<br />
                Glendale, CA 91202
              </p>
            </div>

            <div>
              <p class="text-charcoal-muted text-xs uppercase tracking-widest font-semibold mb-2">Mailing</p>
              <p class="text-charcoal text-base leading-relaxed">
                P.O. Box 5899<br />
                Glendale, CA 91221
              </p>
            </div>

            <div>
              <p class="text-charcoal-muted text-xs uppercase tracking-widest font-semibold mb-2">Hours</p>
              <p class="text-charcoal text-base leading-relaxed">
                Monday – Friday<br />
                9:00 AM – 6:00 PM
              </p>
            </div>

            <div class="pt-6 border-t border-line">
              <p class="text-charcoal-muted text-xs uppercase tracking-widest font-semibold mb-3">Existing Clients</p>
              <div class="flex flex-col">
                <a href="https://protectedxchange.com" target="_blank" rel="noopener noreferrer" class="text-forest text-sm font-medium hover:text-forest-hover transition-colors py-2">
                  → Send a Secure File
                </a>
                <a href="https://portal.bizpayo.com" target="_blank" rel="noopener noreferrer" class="text-forest text-sm font-medium hover:text-forest-hover transition-colors py-2">
                  → Make a Payment
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map -->
  <section class="bg-cream-warm py-20 md:py-24">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto text-center mb-10 fade-in">
        <h2 class="text-3xl md:text-4xl font-serif text-navy mb-4">Visit our Glendale office</h2>
        <p class="text-charcoal text-base">
          300 W Glenoaks Blvd, Suite 101, Glendale, CA 91202.
        </p>
      </div>

      <div class="aspect-[16/9] max-w-4xl mx-auto rounded-lg overflow-hidden border border-line fade-in fade-in-delay-1">
        <iframe
          src="https://www.google.com/maps?q=300+W+Glenoaks+Blvd+Suite+101+Glendale+CA+91202&output=embed"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="CA Accounting — 300 W Glenoaks Blvd, Glendale, CA 91202"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 md:py-24">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12 fade-in">
          <h2 class="text-3xl md:text-4xl font-serif text-navy">Common questions</h2>
        </div>

        <div class="space-y-8">
          {faq.map((item, i) => (
            <div class:list={["pb-6 fade-in", i < faq.length - 1 && "border-b border-line"]}>
              <h3 class="text-lg font-serif text-navy mb-2">{item.q}</h3>
              <p class="text-charcoal-muted text-base leading-relaxed">{item.a}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</Base>
